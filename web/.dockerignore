# Dependencies are installed inside the image by pnpm; never copy the host's
# node_modules (it collides with the image's pnpm store and bloats the build
# context). This also prevents a host `npm install` from breaking `COPY . .`.
node_modules

# Build output — regenerated by `pnpm build` inside the image.
dist

# Local env / secrets — must never enter the image layer.
.env
.env.*
!.env.example

# Local tooling / VCS noise
.git
.gitignore
*.log
.DS_Store
Thumbs.db
