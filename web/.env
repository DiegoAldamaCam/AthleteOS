VITE_API_BASE_URL=http://localhost:8000
# MUST match API_KEY in the root .env (FastAPI reads API_KEY; the SPA sends it as X-API-Key).
# Vite bakes this value into the production bundle at build time — the docker web image
# must be rebuilt after changing this value.
# Copy the value from root .env: API_KEY=<your-value>
VITE_API_KEY=set-this-to-match-root-API_KEY
