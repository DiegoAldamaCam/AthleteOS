    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^3.2.6",
    "@eslint/js": "^9.6.0",
    "eslint": "^9.6.0",
    "globals": "^15.6.0",
    "happy-dom": "^20.0.0",
    "prettier": "^3.3.2",
