POSTGRES_PASSWORD=change-me-db-password
API_KEY=change-me-api-key
JWT_SECRET=change-me-jwt-secret  # min 32 random bytes in production
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin
# Vite build-time vars — Compose reads these from root .env for web build args.
# Must match web/.env (same values). Both files are gitignored.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=change-me-api-key  # copy from API_KEY above
