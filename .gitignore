# Virtual environments
.venv/
.venv311/
venv/
env/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*
!.env.example
!web/.env.example
# web/.env is NOT tracked: it holds VITE_API_KEY, which must match the real
# API_KEY secret at runtime. It was previously force-tracked via `!web/.env` on
# the assumption it held only placeholders; that assumption failed and leaked a
# real key (issue #80). VITE_API_KEY is supplied locally via web/.env (ignored)
# or in CI via a build-arg — never committed. See web/.env.example for the shape.

# Local data / warehouses (never commit data)
warehouse/
data/synthetic/output/
data/samples/lake/
*.log

# Flink checkpoints / savepoints
checkpoints/
savepoints/
flink-logs/
# Per-run integration-test checkpoint dirs (e.g. tests/integration/_checkpoints_<runid>/)
_checkpoints_*/

# Local agent/tooling caches (not project artifacts)
.atl/

# Ephemeral orchestrator prompt scratch files
prompt.md

# Frontend (web/)
web/node_modules/
web/dist/